# Base de datos (Railway la provee automáticamente)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/orderly

# OpenAI
OPENAI_API_KEY=sk-...

# Twilio (credenciales de la cuenta, compartidas para todos los negocios)
TWILIO_ACCOUNT_SID=ACxxxx
TWILIO_AUTH_TOKEN=xxxx

# CORS - dominio del frontend en Vercel
ALLOWED_ORIGINS=http://localhost:3000

# NOTA: Los datos de cada negocio (nombre, número WhatsApp, número del dueño,
# moneda, tiempo estimado) se configuran en la tabla "businesses" de la DB.
# El bot identifica automáticamente el negocio por el número al que le escriben.
